# MySQL Configuration
# MySQL container initialization variables (used by Docker MySQL image)
# ⚠️  REQUIRED: Replace with a STRONG, UNIQUE password before running Docker
MYSQL_ROOT_PASSWORD=CHANGE_ME_SET_STRONG_PASSWORD

# Database and user created by MySQL container on first startup
MYSQL_DATABASE=giftogram_db
MYSQL_USER=giftogram_user
# ⚠️  REQUIRED: Replace with a STRONG, UNIQUE password before running Docker
MYSQL_PASSWORD=CHANGE_ME_SET_STRONG_PASSWORD

# App Database Connection
# These must match the MYSQL_* values above for the app to connect successfully
# DB_HOST should be "db" when running in Docker, "localhost" for local development
DB_HOST=db
DB_PORT=3306
DB_NAME=giftogram_db  # Must match MYSQL_DATABASE
DB_USER=giftogram_user  # Must match MYSQL_USER
# ⚠️  REQUIRED: Must match MYSQL_PASSWORD and be STRONG, UNIQUE
DB_PASSWORD=CHANGE_ME_SET_STRONG_PASSWORD

# Backend Server Port
PORT=3000

# Optional: Session duration in days (default: 7)
# SESSION_DURATION_DAYS=7

# Optional: Frontend API base URL (set in docker-compose.yml, not here)
# VITE_API_BASE_URL=http://localhost:3000
